---
import CitySketchArt from '../components/CitySketchArt.astro';
import { education, experiences, impactStats, profile, projects, skillGroups } from '../data/profile';

const rotations = [
  {
    suit: 'BD',
    title: 'Business Development',
    description: 'Worked on bank-linking friction and merchant payment performance.',
    highlights: ['Add-bank conversion', 'Merchant auth issues', 'AI-assisted pattern finding']
  },
  {
    suit: 'ES',
    title: 'Enterprise Sales',
    description: 'Helped enterprise teams move faster with better research and coordination.',
    highlights: ['Michael Kors integration', 'Merchant proof points', '90% faster research']
  },
  {
    suit: 'PM',
    title: 'Product Marketing',
    description: 'Turned messy merchant identity work into repeatable campaign operations.',
    highlights: ['2x ad revenue', 'Honey-PayPal mapping', '3 months to 2 days']
  },
  {
    suit: 'CI',
    title: 'Customer Insights',
    description: 'Used customer research to help product teams make clearer roadmap calls.',
    highlights: ['Venmo and PayPal research', 'KPI-backed recommendations', 'Customer pain points']
  }
];

const currentYear = new Date().getFullYear();
const pageTitle = `${profile.name} | ${profile.title}`;
const [firstName, ...lastNameParts] = profile.name.split(' ');
const lastName = lastNameParts.join(' ');
const assetPath = (path: string) => (path.startsWith('/') ? path : `/${path}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={profile.summary} />
    <link rel="icon" type="image/svg+xml" href={assetPath('/favicon.svg')} />
    <link rel="icon" type="image/x-icon" href={assetPath('/favicon.ico')} />
    <link rel="apple-touch-icon" sizes="180x180" href={assetPath('/apple-touch-icon.png')} />
    <link rel="icon" type="image/png" sizes="192x192" href={assetPath('/favicon-192.png')} />
    <link rel="icon" type="image/png" sizes="512x512" href={assetPath('/favicon-512.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Space+Mono:wght@400;700&family=Silkscreen&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <style>
      /* ========================================
         DARK THEME (Default)
         ======================================== */
      :root {
        --primary: #06b6d4;
        --primary-dark: #0891b2;
        --accent: #d946ef;
        --accent-dark: #c026d3;

        --bg: #0a0a0f;
        --bg-secondary: #12121a;
        --bg-card: #1a1a24;
        --bg-card-hover: #22222e;

        --text: #f1f5f9;
        --text-secondary: #94a3b8;
        --text-muted: #64748b;

        --border: rgba(6, 182, 212, 0.2);
        --glow: rgba(6, 182, 212, 0.4);
        --glow-accent: rgba(217, 70, 239, 0.3);
      }

      /* ========================================
         LIGHT THEME
         ======================================== */
      [data-theme="light"] {
        --primary: #0891b2;
        --primary-dark: #0e7490;
        --accent: #c026d3;
        --accent-dark: #a21caf;

        --bg: #fafafa;
        --bg-secondary: #f4f4f5;
        --bg-card: #ffffff;
        --bg-card-hover: #f8fafc;

        --text: #18181b;
        --text-secondary: #52525b;
        --text-muted: #a1a1aa;

        --border: rgba(8, 145, 178, 0.15);
        --glow: rgba(8, 145, 178, 0.2);
        --glow-accent: rgba(192, 38, 211, 0.15);
      }

      /* Light theme specific overrides */
      [data-theme="light"] .bg-grid {
        background-image:
          linear-gradient(rgba(8, 145, 178, 0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(8, 145, 178, 0.06) 1px, transparent 1px);
      }

      [data-theme="light"] .bg-gradient {
        background:
          radial-gradient(ellipse 80% 50% at 20% 20%, rgba(8, 145, 178, 0.08) 0%, transparent 50%),
          radial-gradient(ellipse 60% 60% at 80% 80%, rgba(192, 38, 211, 0.06) 0%, transparent 50%);
      }

      [data-theme="light"] .pixel--cyan {
        background: var(--primary);
        box-shadow: 0 0 6px var(--primary);
      }

      [data-theme="light"] .pixel--magenta {
        background: var(--accent);
        box-shadow: 0 0 6px var(--accent);
      }

      [data-theme="light"] .nav {
        background: rgba(250, 250, 250, 0.9);
        border-bottom-color: var(--border);
      }

      [data-theme="light"] .text-glow {
        animation: textGlowLight 4s ease-in-out infinite;
      }

      @keyframes textGlowLight {
        0%, 100% {
          text-shadow: 0 0 10px rgba(8, 145, 178, 0.2), 0 0 20px rgba(192, 38, 211, 0.1);
        }
        50% {
          text-shadow: 0 0 20px rgba(8, 145, 178, 0.3), 0 0 40px rgba(192, 38, 211, 0.2);
        }
      }

      [data-theme="light"] .btn--primary {
        box-shadow: 0 4px 20px rgba(8, 145, 178, 0.25);
      }

      [data-theme="light"] .btn--primary:hover {
        box-shadow: 0 8px 30px rgba(8, 145, 178, 0.35);
      }

      [data-theme="light"] .image-placeholder {
        border-color: var(--primary);
        box-shadow: 0 0 40px rgba(8, 145, 178, 0.15), 0 0 80px rgba(192, 38, 211, 0.08);
        color: var(--primary);
        text-shadow: 0 0 20px rgba(8, 145, 178, 0.4);
      }

      [data-theme="light"] .stat-card:hover,
      [data-theme="light"] .experience-card:hover,
      [data-theme="light"] .skill-group:hover,
      [data-theme="light"] .education-card:hover {
        box-shadow: 0 10px 40px rgba(8, 145, 178, 0.12);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Space Mono', monospace;
        background: var(--bg);
        color: var(--text);
        overflow-x: hidden;
        line-height: 1.6;
        transition: background 0.3s ease, color 0.3s ease;
      }

      /* ========================================
         RIPPLE EFFECT
         ======================================== */
      .ripple {
        position: fixed;
        border-radius: 50%;
        background: var(--primary);
        pointer-events: none;
        transform: translate(-50%, -50%) scale(1);
        animation: ripple-animation 0.6s ease-out forwards;
        z-index: 10000;
        width: 30px;
        height: 30px;
        opacity: 0.7;
        box-shadow: 0 0 20px var(--primary);
      }

      @keyframes ripple-animation {
        0% {
          transform: translate(-50%, -50%) scale(0.5);
          opacity: 0.7;
        }
        100% {
          transform: translate(-50%, -50%) scale(3);
          opacity: 0;
        }
      }

      /* ========================================
         BACKGROUND ELEMENTS
         ======================================== */
      .bg-grid {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        /* Dotted line grid pattern */
        background-image: url("data:image/svg+xml,%3Csvg width='50' height='50' xmlns='http://www.w3.org/2000/svg'%3E%3Cline x1='0' y1='0' x2='50' y2='0' stroke='%2306b6d4' stroke-width='1' stroke-dasharray='3,5'/%3E%3Cline x1='0' y1='0' x2='0' y2='50' stroke='%2306b6d4' stroke-width='1' stroke-dasharray='3,5'/%3E%3C/svg%3E");
        background-size: 50px 50px;
        opacity: 0.4;
        transition: opacity 0.3s ease;
      }

      [data-theme="light"] .bg-grid {
        background-image: url("data:image/svg+xml,%3Csvg width='50' height='50' xmlns='http://www.w3.org/2000/svg'%3E%3Cline x1='0' y1='0' x2='50' y2='0' stroke='%230891b2' stroke-width='1' stroke-dasharray='3,5'/%3E%3Cline x1='0' y1='0' x2='0' y2='50' stroke='%230891b2' stroke-width='1' stroke-dasharray='3,5'/%3E%3C/svg%3E");
        opacity: 0.5;
      }

      .bg-gradient {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background:
          radial-gradient(ellipse 80% 50% at 20% 20%, var(--glow) 0%, transparent 50%),
          radial-gradient(ellipse 60% 60% at 80% 80%, var(--glow-accent) 0%, transparent 50%);
        transition: background 0.3s ease;
      }

      .pixels-container {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 1;
        overflow: hidden;
      }

      .pixel {
        position: absolute;
        width: 6px;
        height: 6px;
        opacity: 0.4;
      }

      .pixel--cyan {
        background: var(--primary);
        box-shadow: 0 0 6px var(--primary);
      }

      .pixel--magenta {
        background: var(--accent);
        box-shadow: 0 0 6px var(--accent);
      }

      @keyframes pixelFloat {
        0%, 100% {
          transform: translateY(0) rotate(0deg);
          opacity: 0.2;
        }
        50% {
          transform: translateY(-20px) rotate(180deg);
          opacity: 0.6;
        }
      }

      /* ========================================
         NAVIGATION
         ======================================== */
      .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        background: rgba(10, 10, 15, 0.8);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        transition: background 0.3s ease;
      }

      .nav__logo {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1.25rem;
        color: var(--text);
        text-decoration: none;
      }

      .nav__logo span {
        color: var(--primary);
      }

      .nav__right {
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .nav__links {
        display: flex;
        gap: 2rem;
        list-style: none;
      }

      .nav__link {
        font-family: 'Silkscreen', cursive;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: color 0.3s ease;
      }

      .nav__link:hover {
        color: var(--primary);
      }

      /* Theme Toggle */
      .theme-toggle {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        cursor: pointer;
        color: var(--text-secondary);
        transition: all 0.3s ease;
      }

      .theme-toggle:hover {
        background: var(--bg-card-hover);
        color: var(--primary);
        border-color: var(--primary);
      }

      .theme-toggle svg {
        width: 18px;
        height: 18px;
      }

      .theme-toggle .icon-sun { display: none; }
      .theme-toggle .icon-moon { display: block; }

      [data-theme="light"] .theme-toggle .icon-sun { display: block; }
      [data-theme="light"] .theme-toggle .icon-moon { display: none; }

      @media (max-width: 768px) {
        .nav__links {
          display: none;
        }
      }

      /* ========================================
         SECTIONS
         ======================================== */
      section {
        position: relative;
        z-index: 10;
        padding: 6rem 2rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 3rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .section-title::before {
        content: '';
        width: 40px;
        height: 3px;
        background: linear-gradient(90deg, var(--primary), var(--accent));
      }

      /* ========================================
         HERO
         ======================================== */
      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 4rem;
        align-items: center;
        padding-top: 8rem;
      }

      @media (max-width: 900px) {
        .hero {
          grid-template-columns: 1fr;
          text-align: center;
          padding-top: 7rem;
        }
      }

      .hero__text {
        opacity: 0;
        animation: slideIn 0.8s ease forwards 0.2s;
      }

      @keyframes slideIn {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .hero__label {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Silkscreen', cursive;
        font-size: 0.875rem;
        color: var(--primary);
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 2px;
      }

      .hero__label::before {
        content: '>';
        animation: blink 1s step-end infinite;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      .hero__title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2.5rem, 7vw, 4.5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
      }

      .hero__title-line {
        display: block;
      }

      .text-glow {
        animation: textGlow 4s ease-in-out infinite;
      }

      @keyframes textGlow {
        0%, 100% {
          text-shadow: 0 0 10px var(--glow), 0 0 20px var(--glow-accent);
        }
        50% {
          text-shadow: 0 0 20px var(--glow), 0 0 40px var(--glow-accent);
        }
      }

      .text-gradient {
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .hero__subtitle {
        font-size: 1.1rem;
        color: var(--text-secondary);
        line-height: 1.8;
        margin-bottom: 2rem;
        max-width: 500px;
      }

      @media (max-width: 900px) {
        .hero__subtitle {
          margin: 0 auto 2rem;
        }
      }

      .hero__cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      @media (max-width: 900px) {
        .hero__cta {
          justify-content: center;
        }
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.75rem;
        font-family: 'Silkscreen', cursive;
        font-size: 0.8rem;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s ease;
      }

      .btn--primary {
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: white;
        box-shadow: 0 0 20px var(--glow);
      }

      .btn--primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 0 30px var(--glow);
      }

      .btn--secondary {
        background: transparent;
        color: var(--primary);
        border: 1px solid var(--primary);
      }

      .btn--secondary:hover {
        background: var(--glow);
        transform: translateY(-3px);
      }

      /* Hero Image */
      .hero__image {
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        animation: slideIn 0.8s ease forwards 0.4s;
      }

      /* Profile Image */
      .profile-container {
        position: relative;
        width: 320px;
        height: 400px;
      }

      @media (max-width: 900px) {
        .profile-container {
          width: 260px;
          height: 325px;
        }
      }

      .profile-image-wrapper {
        position: relative;
        width: 100%;
        height: 100%;
        padding: 4px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      }

      .profile-image-inner {
        position: relative;
        width: 100%;
        height: 100%;
        background: var(--bg);
        padding: 6px;
        overflow: hidden;
      }

      .profile-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: filter 0.5s ease, transform 0.5s ease;
        position: absolute;
        top: 0;
        left: 0;
      }

      /* Dark mode: show dreamy, hide light */
      .profile-image--dark {
        opacity: 1;
      }
      .profile-image--light {
        opacity: 0;
      }

      /* Light mode: show light, hide dreamy */
      [data-theme="light"] .profile-image--dark {
        opacity: 0;
      }
      [data-theme="light"] .profile-image--light {
        opacity: 1;
      }

      .profile-container:hover .profile-image {
        transform: scale(1.02);
      }

      /* Corner accents */
      .corner-accent {
        position: absolute;
        width: 24px;
        height: 24px;
        z-index: 10;
        transition: all 0.3s ease;
      }

      .corner-accent--tl {
        top: -4px;
        left: -4px;
        border-left: 3px solid var(--primary);
        border-top: 3px solid var(--primary);
      }

      .corner-accent--tr {
        top: -4px;
        right: -4px;
        border-right: 3px solid var(--accent);
        border-top: 3px solid var(--accent);
      }

      .corner-accent--bl {
        bottom: -4px;
        left: -4px;
        border-left: 3px solid var(--accent);
        border-bottom: 3px solid var(--accent);
      }

      .corner-accent--br {
        bottom: -4px;
        right: -4px;
        border-right: 3px solid var(--primary);
        border-bottom: 3px solid var(--primary);
      }

      .profile-container:hover .corner-accent {
        width: 32px;
        height: 32px;
      }

      /* Glow effect */
      .profile-glow {
        position: absolute;
        inset: -20px;
        background: radial-gradient(ellipse at center, var(--glow) 0%, transparent 70%);
        opacity: 0.5;
        z-index: -1;
        animation: profilePulse 4s ease-in-out infinite;
      }

      @keyframes profilePulse {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.05); }
      }

      /* ========================================
         IMPACT STATS
         ======================================== */
      .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        grid-column: 1 / -1;
        width: 100%;
        margin-top: 4rem;
        opacity: 0;
        animation: slideIn 0.8s ease forwards 0.6s;
      }

      @media (max-width: 768px) {
        .stats {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      .stat-card {
        background: var(--bg-card);
        padding: 1.35rem 1rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
        border: 1px solid var(--border);
      }

      .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--primary), var(--accent));
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
      }

      .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px var(--glow);
      }

      .stat-card:hover::before {
        transform: scaleX(1);
      }

      .stat-card__value {
        font-family: 'Syne', sans-serif;
        font-size: clamp(1.45rem, 2.8vw, 1.85rem);
        font-weight: 800;
        line-height: 1;
        white-space: nowrap;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .stat-card__label {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        line-height: 1.35;
        margin-top: 0.7rem;
      }

      .stat-card__sublabel {
        font-size: 0.625rem;
        color: var(--text-muted);
        opacity: 0.7;
        line-height: 1.45;
        margin-top: 0.125rem;
      }

      /* ========================================
         EXPERIENCE
         ======================================== */
      .experience-card {
        background: var(--bg-card);
        padding: 2rem;
        margin-bottom: 1.5rem;
        position: relative;
        transition: all 0.3s ease;
        border-left: 3px solid transparent;
        border: 1px solid var(--border);
        border-left: 3px solid transparent;
      }

      .experience-card:hover {
        border-left-color: var(--primary);
        transform: translateX(5px);
        box-shadow: 0 5px 30px var(--glow);
      }

      .experience-card__body {
        width: calc(100% - clamp(8rem, 24%, 13rem));
        max-width: 48rem;
      }

      .experience-card__header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .experience-card__title {
        font-family: 'Syne', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text);
      }

      .experience-card__company {
        color: var(--primary);
        font-size: 0.9rem;
      }

      .experience-card__period {
        font-family: 'Silkscreen', cursive;
        font-size: 0.75rem;
        color: var(--text-muted);
        white-space: nowrap;
      }

      .experience-card__current {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Silkscreen', cursive;
        font-size: 0.625rem;
        color: var(--primary);
        background: var(--glow);
        padding: 0.25rem 0.75rem;
        margin-left: 0.5rem;
      }

      .experience-card__current::before {
        content: '';
        width: 6px;
        height: 6px;
        background: var(--primary);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }

      .experience-card__highlights {
        list-style: none;
      }

      .experience-card__highlight {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
        color: var(--text-secondary);
        font-size: 0.9rem;
      }

      .experience-card__highlight::before {
        content: '→';
        position: absolute;
        left: 0;
        color: var(--accent);
      }

      @media (max-width: 560px) {
        .experience-card__body {
          width: 100%;
          max-width: 100%;
        }

        .experience-card__period {
          white-space: normal;
        }
      }

      /* ========================================
         ROTATION CARDS (DIAGONAL SLIDER STYLE)
         ======================================== */
      .rotations-container {
        margin-top: 2rem;
        padding: 3rem 1rem;
      }

      .rotations-grid {
        position: relative;
        height: 450px;
        max-width: 600px;
        margin: 0 auto;
        overflow: hidden;
      }

      .rotation-card {
        background: var(--bg-card);
        border: 2px solid var(--border);
        border-radius: 12px;
        padding: 2rem;
        position: absolute;
        width: 100%;
        max-width: 500px;
        min-height: 380px;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: all 0.7s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        opacity: 0;
        pointer-events: none;
      }

      /* Active card - centered and visible */
      .rotation-card.active {
        opacity: 1;
        pointer-events: auto;
        transform: translate(-50%, -50%) scale(1);
        z-index: 2;
        box-shadow: 0 20px 60px var(--glow);
        border-color: var(--primary);
      }

      /* Slide out animations */
      .rotation-card.slide-out-top-left {
        transform: translate(-150%, -150%) scale(0.8) rotate(-15deg);
        opacity: 0;
      }

      .rotation-card.slide-out-top-right {
        transform: translate(50%, -150%) scale(0.8) rotate(15deg);
        opacity: 0;
      }

      .rotation-card.slide-out-bottom-left {
        transform: translate(-150%, 50%) scale(0.8) rotate(-15deg);
        opacity: 0;
      }

      .rotation-card.slide-out-bottom-right {
        transform: translate(50%, 50%) scale(0.8) rotate(15deg);
        opacity: 0;
      }

      /* Slide in animations - start positions */
      .rotation-card.slide-in-top-left {
        transform: translate(-150%, -150%) scale(0.8) rotate(-15deg);
        opacity: 0;
      }

      .rotation-card.slide-in-top-right {
        transform: translate(50%, -150%) scale(0.8) rotate(15deg);
        opacity: 0;
      }

      .rotation-card.slide-in-bottom-left {
        transform: translate(-150%, 50%) scale(0.8) rotate(-15deg);
        opacity: 0;
      }

      .rotation-card.slide-in-bottom-right {
        transform: translate(50%, 50%) scale(0.8) rotate(15deg);
        opacity: 0;
      }

      .rotation-card__suit {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        font-size: 2rem;
        opacity: 0.3;
      }

      .rotation-card__suit-bottom {
        position: absolute;
        bottom: 0.75rem;
        right: 0.75rem;
        font-size: 2rem;
        opacity: 0.3;
        transform: rotate(180deg);
      }

      .rotation-card__content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 2.5rem;
      }

      .rotation-card__title {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--primary);
        text-align: center;
        line-height: 1.2;
      }

      .rotation-card__description {
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-align: center;
        line-height: 1.4;
      }

      .rotation-card__highlights {
        list-style: none;
        margin-top: auto;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
      }

      .rotation-card__highlight {
        font-size: 0.75rem;
        color: var(--text-muted);
        padding: 0.25rem 0;
        position: relative;
        padding-left: 1rem;
      }

      .rotation-card__highlight::before {
        content: '•';
        position: absolute;
        left: 0;
        color: var(--accent);
      }

      /* Icon styling - all same opacity */
      .rotation-card__suit,
      .rotation-card__suit-bottom {
        filter: grayscale(0);
        opacity: 0.4;
      }

      /* Card navigation */
      .card-nav {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin-top: 1.5rem;
      }

      .card-nav__hint {
        font-family: 'Silkscreen', cursive;
        font-size: 0.625rem;
        color: var(--text-muted);
        text-align: center;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        animation: fadeInBounce 2s ease-in-out infinite;
      }

      @keyframes fadeInBounce {
        0%, 100% { opacity: 0.4; transform: translateY(0); }
        50% { opacity: 0.8; transform: translateY(-3px); }
      }

      .card-nav__arrow {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
        color: var(--text-secondary);
      }

      .card-nav__arrow:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
      }

      .card-nav__dots {
        display: flex;
        gap: 0.5rem;
      }

      .card-nav__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--border);
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .card-nav__dot.active {
        background: var(--primary);
        width: 24px;
        border-radius: 4px;
      }

      /* ========================================
         SKILLS
         ======================================== */
      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
      }

      .skill-group {
        background: var(--bg-card);
        padding: 1.5rem;
        transition: all 0.3s ease;
        border: 1px solid var(--border);
      }

      .skill-group:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 20px var(--glow);
      }

      .skill-group__title {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
      }

      .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .skill-tag {
        font-size: 0.75rem;
        padding: 0.375rem 0.75rem;
        background: var(--bg-secondary);
        color: var(--text-secondary);
        transition: all 0.2s ease;
      }

      .skill-tag:hover {
        background: var(--glow);
        color: var(--primary);
      }

      /* ========================================
         PROJECTS
         ======================================== */
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
      }

      .project-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 1.5rem;
        transition: all 0.3s ease;
      }

      .project-card:first-child {
        grid-column: span 2;
      }

      .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 28px var(--glow);
      }

      .project-card__context {
        font-family: 'Silkscreen', cursive;
        font-size: 0.625rem;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 1px;
        line-height: 1.35;
        margin-bottom: 0.75rem;
      }

      .project-card__title {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        line-height: 1.2;
        color: var(--text);
        margin-bottom: 0.75rem;
      }

      .project-card__description {
        color: var(--text-secondary);
        font-size: 0.85rem;
      }

      @media (max-width: 640px) {
        .project-card:first-child {
          grid-column: span 1;
        }
      }

      /* ========================================
         EDUCATION
         ======================================== */
      .education-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
      }

      .education-card {
        background: var(--bg-card);
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        border: 1px solid var(--border);
      }

      .education-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 20px var(--glow-accent);
      }

      .education-card__year {
        font-family: 'Silkscreen', cursive;
        font-size: 0.875rem;
        color: var(--accent);
        margin-bottom: 0.5rem;
      }

      .education-card__degree {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.25rem;
        color: var(--text);
      }

      .education-card__school {
        color: var(--text-secondary);
        font-size: 0.875rem;
        margin-bottom: 0.5rem;
      }

      .education-card__detail {
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      /* ========================================
         CONTACT
         ======================================== */
      .contact {
        text-align: center;
        padding: 8rem 2rem;
      }

      .contact__title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        margin-bottom: 1rem;
      }

      .contact__subtitle {
        color: var(--text-secondary);
        max-width: 500px;
        margin: 0 auto 2rem;
      }

      .contact__buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 2rem;
      }

      .social-links {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2rem;
      }

      .social-link {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-card);
        color: var(--text-secondary);
        transition: all 0.3s ease;
        border: 1px solid var(--border);
      }

      .social-link:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-3px);
        border-color: var(--primary);
      }

      /* ========================================
         FOOTER
         ======================================== */
      .footer {
        padding: 2rem;
        text-align: center;
        border-top: 1px solid var(--border);
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .footer span {
        color: var(--primary);
      }

      /* ========================================
         SCROLL INDICATOR
         ======================================== */
      .scroll-indicator {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 20;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        opacity: 0;
        animation: fadeIn 1s ease forwards 1.5s;
      }

      @keyframes fadeIn {
        to { opacity: 1; }
      }

      .scroll-indicator__line {
        width: 1px;
        height: 40px;
        background: linear-gradient(to bottom, var(--primary), transparent);
        animation: scrollPulse 2s ease-in-out infinite;
      }

      @keyframes scrollPulse {
        0%, 100% { height: 40px; opacity: 0.5; }
        50% { height: 60px; opacity: 1; }
      }

      .scroll-indicator__text {
        font-family: 'Silkscreen', cursive;
        font-size: 0.5rem;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 2px;
      }
    </style>
  </head>
  <body>
    <!-- Background -->
    <div class="bg-grid"></div>
    <div class="bg-gradient"></div>
    <div class="pixels-container" id="pixels"></div>

    <!-- Navigation -->
    <nav class="nav">
      <div class="nav__right">
        <ul class="nav__links">
          <li><a href="#experience" class="nav__link">Experience</a></li>
          <li><a href="#projects" class="nav__link">Projects</a></li>
          <li><a href="#skills" class="nav__link">Skills</a></li>
          <li><a href="#education" class="nav__link">Education</a></li>
          <li><a href="#contact" class="nav__link">Contact</a></li>
        </ul>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <svg class="icon-moon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
          <svg class="icon-sun" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero" id="home">
      <div class="hero__text">
        <div class="hero__label">{profile.label}</div>
        <h1 class="hero__title">
          <span class="hero__title-line text-glow">{firstName}</span>
          <span class="hero__title-line text-gradient">{lastName}</span>
        </h1>
        <p class="hero__subtitle">
          {profile.summary}
        </p>
        <div class="hero__cta">
          <a href="#contact" class="btn btn--primary">Talk AI + Product</a>
          <a href="#projects" class="btn btn--secondary">See Projects</a>
          <a href={assetPath(profile.resumePath)} download class="btn btn--secondary">Download Resume</a>
        </div>
      </div>

      <div class="hero__image">
        <div class="profile-container">
          <div class="profile-glow"></div>
          <div class="corner-accent corner-accent--tl"></div>
          <div class="corner-accent corner-accent--tr"></div>
          <div class="corner-accent corner-accent--bl"></div>
          <div class="corner-accent corner-accent--br"></div>
          <div class="profile-image-wrapper">
            <div class="profile-image-inner">
              <img src={assetPath('/profile-ai-dreamy.jpg')} alt={profile.name} class="profile-image profile-image--dark" />
              <img src={assetPath('/profile-light.jpg')} alt={profile.name} class="profile-image profile-image--light" />
            </div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats">
        {impactStats.map((item) => (
          <div class="stat-card">
            <div class="stat-card__value">{item.metric}</div>
            <div class="stat-card__label">{item.label}</div>
            {item.sublabel && <div class="stat-card__sublabel">{item.sublabel}</div>}
          </div>
        ))}
      </div>
    </section>

    <!-- Scroll Indicator -->
    <div class="scroll-indicator" id="scroll-indicator">
      <div class="scroll-indicator__line"></div>
      <span class="scroll-indicator__text">Scroll</span>
    </div>

    <!-- Experience Section -->
    <section id="experience">
      <h2 class="section-title">Experience</h2>
      {experiences.map((exp) => (
        <div class="experience-card">
          {exp.locationId && <CitySketchArt cityId={exp.locationId} />}
          <div class="experience-card__body">
            <div class="experience-card__header">
              <div>
                <div class="experience-card__title">
                  {exp.title}
                  {exp.isCurrent && <span class="experience-card__current">Current</span>}
                </div>
                <div class="experience-card__company">
                  {exp.company}
                  {exp.locationId ? (
                    <span class="city-inline">
                      {exp.location}
                    </span>
                  ) : exp.location ? (
                    <span> · {exp.location}</span>
                  ) : null}
                </div>
              </div>
              <div class="experience-card__period">{exp.period}</div>
            </div>
            <ul class="experience-card__highlights">
              {exp.highlights.map((highlight) => (
                <li class="experience-card__highlight">{highlight}</li>
              ))}
            </ul>
          </div>

          {exp.hasRotations && (
            <div class="rotations-container">
              <div class="rotations-grid" id="rotations-grid">
                {rotations.map((rotation, index) => (
                  <div class="rotation-card" data-index={index}>
                    <span class="rotation-card__suit">{rotation.suit}</span>
                    <div class="rotation-card__content">
                      <h3 class="rotation-card__title">{rotation.title}</h3>
                      <p class="rotation-card__description">{rotation.description}</p>
                    </div>
                    <ul class="rotation-card__highlights">
                      {rotation.highlights.map((highlight) => (
                        <li class="rotation-card__highlight">{highlight}</li>
                      ))}
                    </ul>
                    <span class="rotation-card__suit-bottom">{rotation.suit}</span>
                  </div>
                ))}
              </div>
              <div class="card-nav__hint" id="card-hint">← Swipe or click arrows to explore rotations →</div>
              <div class="card-nav">
                <button class="card-nav__arrow" id="card-prev">‹</button>
                <div class="card-nav__dots" id="card-dots">
                  {rotations.map((_, index) => (
                    <span class="card-nav__dot" data-index={index}></span>
                  ))}
                </div>
                <button class="card-nav__arrow" id="card-next">›</button>
              </div>
            </div>
          )}
        </div>
      ))}
    </section>

    <!-- Projects Section -->
    <section id="projects">
      <h2 class="section-title">Projects & Recognition</h2>
      <div class="projects-grid">
        {projects.map((project) => (
          <article class="project-card">
            <div class="project-card__context">{project.context}</div>
            <h3 class="project-card__title">{project.title}</h3>
            <p class="project-card__description">{project.description}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Skills Section -->
    <section id="skills">
      <h2 class="section-title">Skills</h2>
      <div class="skills-grid">
        {skillGroups.map((group) => (
          <div class="skill-group">
            <div class="skill-group__title">{group.name}</div>
            <div class="skill-tags">
              {group.skills.map((skill) => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education Section -->
    <section id="education">
      <h2 class="section-title">Education</h2>
      <div class="education-grid">
        {education.map((edu) => (
          <div class="education-card">
            {edu.locationId && <CitySketchArt cityId={edu.locationId} />}
            <div class="education-card__year">{edu.year}</div>
            <div class="education-card__degree">{edu.degree}</div>
            <div class="education-card__school">
              {edu.school}
              {edu.locationId ? (
                <span class="city-inline">
                  {edu.location}
                </span>
              ) : edu.location ? (
                <span> · {edu.location}</span>
              ) : null}
            </div>
            <div class="education-card__detail">{edu.detail}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact Section -->
    <section class="contact" id="contact">
      <h2 class="contact__title text-gradient">Let's Connect</h2>
      <p class="contact__subtitle">
        {profile.contactPrompt}
      </p>
      <div class="contact__buttons">
        <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn--secondary">LinkedIn</a>
      </div>
      <div class="social-links">
        <a href={profile.linkedin} target="_blank" rel="noopener noreferrer" class="social-link">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={profile.github} target="_blank" rel="noopener noreferrer" class="social-link">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <p>© {currentYear} {profile.name} · Built with <span>Astro</span></p>
    </footer>

    <script is:inline>
      // Floating pixels
      const pixelsContainer = document.getElementById('pixels');
      for (let i = 0; i < 20; i++) {
        const pixel = document.createElement('div');
        pixel.classList.add('pixel');
        pixel.classList.add(Math.random() > 0.5 ? 'pixel--cyan' : 'pixel--magenta');
        pixel.style.cssText = `
          left: ${Math.random() * 100}%;
          top: ${Math.random() * 100}%;
          animation: pixelFloat ${8 + Math.random() * 4}s ease-in-out infinite;
          animation-delay: -${Math.random() * 8}s;
        `;
        pixelsContainer.appendChild(pixel);
      }

      // Click ripple effect - sonic boom style
      document.addEventListener('click', (e) => {
        const ripple = document.createElement('div');
        ripple.style.cssText = `
          position: fixed;
          left: ${e.clientX}px;
          top: ${e.clientY}px;
          width: 20px;
          height: 20px;
          border: 2px solid rgba(6, 182, 212, 0.6);
          border-radius: 50%;
          transform: translate(-50%, -50%);
          pointer-events: none;
          z-index: 999999;
          opacity: 0.8;
          box-shadow: 0 0 10px rgba(6, 182, 212, 0.3);
        `;
        document.body.appendChild(ripple);

        // Animate with JavaScript - wave expanding outward
        let scale = 1;
        let opacity = 0.8;
        const animate = () => {
          scale += 0.06;
          opacity -= 0.015;
          ripple.style.transform = `translate(-50%, -50%) scale(${scale})`;
          ripple.style.opacity = opacity;

          if (opacity > 0) {
            requestAnimationFrame(animate);
          } else {
            ripple.remove();
          }
        };
        requestAnimationFrame(animate);
      });

      // Rotation cards navigation with diagonal transitions
      const rotationCards = document.querySelectorAll('.rotation-card');
      const cardDots = document.querySelectorAll('.card-nav__dot');
      const cardPrev = document.getElementById('card-prev');
      const cardNext = document.getElementById('card-next');
      const cardHint = document.getElementById('card-hint');
      let activeCardIndex = 0;
      let isAnimating = false;
      let hasInteracted = false;

      function hideHint() {
        if (!hasInteracted && cardHint) {
          cardHint.style.opacity = '0';
          cardHint.style.transition = 'opacity 0.5s ease';
          hasInteracted = true;
          setTimeout(() => {
            cardHint.style.display = 'none';
          }, 500);
        }
      }

      // Diagonal directions cycle through corners
      const directions = ['top-left', 'top-right', 'bottom-right', 'bottom-left'];

      function setActiveCard(newIndex, direction = 'next') {
        if (isAnimating || newIndex === activeCardIndex) return;
        if (newIndex < 0 || newIndex >= rotationCards.length) return;

        isAnimating = true;
        const currentCard = rotationCards[activeCardIndex];
        const nextCard = rotationCards[newIndex];

        // Determine slide direction based on navigation
        const currentDirection = directions[activeCardIndex % directions.length];
        const nextDirection = directions[newIndex % directions.length];

        // Slide out current card
        if (currentCard) {
          currentCard.classList.remove('active');
          currentCard.classList.add(`slide-out-${currentDirection}`);
        }

        // Prepare next card to slide in
        if (nextCard) {
          nextCard.classList.add(`slide-in-${nextDirection}`);

          // Trigger slide in after a brief delay
          setTimeout(() => {
            nextCard.classList.remove(`slide-in-${nextDirection}`);
            nextCard.classList.add('active');
          }, 50);
        }

        // Update dots
        cardDots.forEach(dot => dot.classList.remove('active'));
        if (cardDots[newIndex]) {
          cardDots[newIndex].classList.add('active');
        }

        // Clean up classes after animation
        setTimeout(() => {
          if (currentCard) {
            currentCard.classList.remove(`slide-out-${currentDirection}`);
          }
          isAnimating = false;
        }, 700);

        activeCardIndex = newIndex;
      }

      // Initialize first card as active
      if (rotationCards.length > 0) {
        rotationCards[0].classList.add('active');
        if (cardDots[0]) cardDots[0].classList.add('active');
      }

      // Navigation arrows
      if (cardPrev) {
        cardPrev.addEventListener('click', () => {
          hideHint();
          const newIndex = (activeCardIndex - 1 + rotationCards.length) % rotationCards.length;
          setActiveCard(newIndex, 'prev');
        });
      }

      if (cardNext) {
        cardNext.addEventListener('click', () => {
          hideHint();
          const newIndex = (activeCardIndex + 1) % rotationCards.length;
          setActiveCard(newIndex, 'next');
        });
      }

      // Dot navigation
      cardDots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          hideHint();
          const direction = index > activeCardIndex ? 'next' : 'prev';
          setActiveCard(index, direction);
        });
      });

      // Swipe support for mobile and desktop
      let touchStartX = 0;
      let touchEndX = 0;
      let isDragging = false;
      const rotationsGrid = document.getElementById('rotations-grid');

      function handleSwipe() {
        const swipeThreshold = 50;
        const diff = touchEndX - touchStartX;

        if (diff < -swipeThreshold) {
          hideHint();
          // Swipe left - next card
          const newIndex = (activeCardIndex + 1) % rotationCards.length;
          setActiveCard(newIndex, 'next');
        } else if (diff > swipeThreshold) {
          hideHint();
          // Swipe right - previous card
          const newIndex = (activeCardIndex - 1 + rotationCards.length) % rotationCards.length;
          setActiveCard(newIndex, 'prev');
        }
      }

      if (rotationsGrid) {
        // Touch events for mobile
        rotationsGrid.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        rotationsGrid.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          handleSwipe();
        });

        // Mouse events for desktop
        rotationsGrid.addEventListener('mousedown', (e) => {
          isDragging = true;
          touchStartX = e.clientX;
          rotationsGrid.style.cursor = 'grabbing';
        });

        rotationsGrid.addEventListener('mousemove', (e) => {
          if (!isDragging) return;
          touchEndX = e.clientX;
        });

        rotationsGrid.addEventListener('mouseup', (e) => {
          if (!isDragging) return;
          isDragging = false;
          touchEndX = e.clientX;
          rotationsGrid.style.cursor = 'default';
          handleSwipe();
        });

        rotationsGrid.addEventListener('mouseleave', () => {
          if (isDragging) {
            isDragging = false;
            rotationsGrid.style.cursor = 'default';
          }
        });
      }

      // Theme toggle
      const themeToggle = document.getElementById('theme-toggle');
      const html = document.documentElement;

      // Check for saved theme preference or default to light
      const savedTheme = localStorage.getItem('theme') || 'light';
      if (savedTheme === 'light') {
        html.setAttribute('data-theme', 'light');
      }

      themeToggle.addEventListener('click', () => {
        const currentTheme = html.getAttribute('data-theme');
        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
        if (newTheme === 'light') {
          html.setAttribute('data-theme', 'light');
        } else {
          html.removeAttribute('data-theme');
        }
        localStorage.setItem('theme', newTheme);
      });

      // Hide scroll indicator on scroll
      const scrollIndicator = document.getElementById('scroll-indicator');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 100) {
          scrollIndicator.style.opacity = '0';
        }
      });

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

    </script>
  </body>
</html>
