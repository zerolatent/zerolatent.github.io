---
const cities = [
  {
    id: 'austin',
    name: 'Austin',
    label: 'Austin, TX',
    chapter: 'Current base',
    detail: 'AI product engineering, BNPL quality strategy, and practical LLM workflows at PayPal.',
    stat: '2020 - Present',
    sketchNote: 'Skyline, river, and Capitol-inspired dome'
  },
  {
    id: 'baltimore',
    name: 'Baltimore',
    label: 'Baltimore, MD',
    chapter: 'Backend engineering',
    detail: 'Early PayPal Credit years building backend systems, automation, and release confidence.',
    stat: '2014 - 2020',
    sketchNote: 'Harbor waterline, rowhouses, and cranes'
  },
  {
    id: 'memphis',
    name: 'Memphis',
    label: 'Memphis, TN',
    chapter: 'Graduate work',
    detail: 'MS Computer Engineering, AI coursework, pattern recognition, and Computer Intelligence Lab research.',
    stat: '2011 - 2013',
    sketchNote: 'River bridge, pyramid, and bluff skyline'
  },
  {
    id: 'hyderabad',
    name: 'Hyderabad',
    label: 'Hyderabad, India',
    chapter: 'Engineering roots',
    detail: 'Undergrad foundation in electronics and computer engineering before moving into AI and fintech work.',
    stat: '2007 - 2011',
    sketchNote: 'Charminar-inspired arches and minarets'
  },
  {
    id: 'london',
    name: 'London',
    label: 'London, UK',
    chapter: 'Concept sketch',
    detail: 'A non-resume concept sketch using the Thames, Tower Bridge, a clock tower, and layered skyline to test how the city interaction scales.',
    stat: 'Prototype',
    sketchNote: 'Thames, Tower Bridge, clock tower, and skyline'
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="A pencil-sketch prototype for city mentions in Siddartha Posam's portfolio."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>City Sketch Prototype | Siddartha Posam</title>
    <style>
      :root {
        --bg: #07080d;
        --paper: #f2eee4;
        --paper-shadow: #c8beb0;
        --panel: rgba(15, 18, 28, 0.78);
        --text: #f4f7fb;
        --text-soft: #aeb8c8;
        --text-muted: #6d788b;
        --cyan: #17c7d9;
        --gold: #ffd166;
        --pencil: #2e3440;
        --pencil-soft: rgba(46, 52, 64, 0.48);
        --border: rgba(174, 184, 200, 0.14);
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.34);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at 20% 10%, rgba(23, 199, 217, 0.14), transparent 32rem),
          radial-gradient(circle at 86% 78%, rgba(255, 209, 102, 0.11), transparent 30rem),
          linear-gradient(135deg, #07080d 0%, #10131b 52%, #090b12 100%);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.85), transparent 85%);
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 32px 0 56px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--text-soft);
        font-size: 0.9rem;
        text-decoration: none;
      }

      .brand-mark {
        display: grid;
        place-items: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.04);
        color: var(--cyan);
        font-weight: 800;
      }

      .back-link {
        color: var(--text-soft);
        font-size: 0.86rem;
        text-decoration: none;
        border: 1px solid var(--border);
        padding: 9px 12px;
        background: rgba(255, 255, 255, 0.04);
        transition: border-color 180ms ease, color 180ms ease;
      }

      .back-link:hover {
        color: var(--text);
        border-color: rgba(23, 199, 217, 0.48);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(430px, 1.1fr);
        grid-template-areas:
          "intro sketch"
          "timeline sketch";
        gap: 32px;
        align-items: stretch;
      }

      .intro {
        grid-area: intro;
      }

      .eyebrow {
        color: var(--cyan);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        margin: 0 0 18px;
      }

      h1 {
        max-width: 720px;
        margin: 0;
        font-size: clamp(3rem, 8vw, 6.4rem);
        line-height: 0.86;
        letter-spacing: 0;
      }

      .intro-copy {
        max-width: 620px;
        margin: 24px 0 0;
        color: var(--text-soft);
        font-size: 1.04rem;
        line-height: 1.7;
      }

      .city-options {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
      }

      .city-chip {
        appearance: none;
        border: 1px solid rgba(23, 199, 217, 0.36);
        color: var(--text);
        background: rgba(23, 199, 217, 0.08);
        padding: 2px 8px;
        margin: 0;
        font: inherit;
        cursor: pointer;
        transition:
          background 160ms ease,
          border-color 160ms ease,
          color 160ms ease,
          box-shadow 160ms ease;
      }

      .city-chip:hover,
      .city-chip:focus-visible,
      .city-chip.is-active {
        outline: none;
        color: #041016;
        background: var(--cyan);
        border-color: var(--cyan);
        box-shadow: 0 0 22px rgba(23, 199, 217, 0.34);
      }

      .timeline {
        grid-area: timeline;
        align-self: end;
        display: grid;
        gap: 12px;
      }

      .moment {
        display: grid;
        grid-template-columns: 92px 1fr;
        gap: 16px;
        padding: 16px 0;
        border-top: 1px solid var(--border);
      }

      .moment:last-child {
        border-bottom: 1px solid var(--border);
      }

      .moment__date {
        color: var(--text-muted);
        font-size: 0.78rem;
        line-height: 1.45;
      }

      .moment__text {
        margin: 0;
        color: var(--text-soft);
        line-height: 1.6;
      }

      .sketch-panel {
        grid-area: sketch;
        position: sticky;
        top: 24px;
        min-height: 650px;
        display: grid;
        grid-template-rows: 1fr auto;
        gap: 18px;
      }

      .sketchbook {
        position: relative;
        display: grid;
        place-items: center;
        min-height: 455px;
        overflow: hidden;
        border: 1px solid var(--border);
        background:
          linear-gradient(150deg, rgba(255, 255, 255, 0.06), transparent 42%),
          rgba(255, 255, 255, 0.035);
        box-shadow: var(--shadow);
      }

      .paper {
        position: relative;
        width: min(92%, 720px);
        aspect-ratio: 1.62 / 1;
        background:
          radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.78), transparent 24%),
          repeating-linear-gradient(0deg, rgba(46, 52, 64, 0.035) 0 1px, transparent 1px 9px),
          var(--paper);
        border: 1px solid rgba(46, 52, 64, 0.12);
        box-shadow:
          0 18px 54px rgba(0, 0, 0, 0.34),
          10px 10px 0 rgba(255, 255, 255, 0.06),
          inset 0 0 0 10px rgba(255, 255, 255, 0.22);
        transform: rotate(-1deg);
      }

      .paper::before,
      .paper::after {
        content: "";
        position: absolute;
        inset: 18px;
        pointer-events: none;
      }

      .paper::before {
        border: 1px solid rgba(46, 52, 64, 0.1);
      }

      .paper::after {
        background-image:
          linear-gradient(110deg, transparent 0 82%, rgba(46, 52, 64, 0.04) 83% 84%, transparent 85%),
          linear-gradient(70deg, transparent 0 88%, rgba(46, 52, 64, 0.035) 89% 90%, transparent 91%);
        background-size: 64px 64px, 72px 72px;
        mix-blend-mode: multiply;
      }

      .sketch-svg {
        position: absolute;
        inset: 8%;
        width: 84%;
        height: 84%;
        overflow: visible;
      }

      .sketch {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 220ms ease, transform 220ms ease;
      }

      .sketch.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .pencil-line,
      .pencil-detail,
      .pencil-shade,
      .pencil-ghost,
      .pencil-fill {
        stroke: var(--pencil);
        stroke-linecap: round;
        stroke-linejoin: round;
        vector-effect: non-scaling-stroke;
      }

      .pencil-line {
        fill: none;
        stroke-width: 2.4;
        filter: url(#rough-pencil);
      }

      .pencil-detail {
        fill: none;
        stroke-width: 1.25;
        opacity: 0.7;
      }

      .pencil-shade {
        fill: none;
        stroke: var(--pencil-soft);
        stroke-width: 1;
        opacity: 0.72;
      }

      .pencil-ghost {
        fill: none;
        stroke: rgba(46, 52, 64, 0.24);
        stroke-width: 0.9;
        opacity: 0.8;
      }

      .pencil-fill {
        fill: rgba(46, 52, 64, 0.055);
        stroke-width: 1.2;
        opacity: 0.96;
      }

      .sketch-title {
        fill: var(--pencil);
        font: 700 32px Inter, system-ui, sans-serif;
        letter-spacing: 0;
      }

      .sketch-note {
        fill: rgba(46, 52, 64, 0.64);
        font: 500 16px Inter, system-ui, sans-serif;
      }

      .detail-panel {
        border: 1px solid var(--border);
        background: var(--panel);
        padding: 22px;
        backdrop-filter: blur(18px);
      }

      .detail-panel__kicker {
        margin: 0 0 8px;
        color: var(--cyan);
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .detail-panel__title {
        margin: 0;
        font-size: clamp(1.7rem, 4vw, 2.6rem);
        line-height: 1;
      }

      .detail-panel__meta {
        margin: 8px 0 0;
        color: var(--gold);
        font-size: 0.84rem;
        font-weight: 700;
      }

      .detail-panel__copy {
        min-height: 54px;
        margin: 16px 0 0;
        color: var(--text-soft);
        line-height: 1.65;
      }

      .legend {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }

      .legend__item {
        border: 1px solid var(--border);
        color: var(--text-soft);
        background: rgba(255, 255, 255, 0.035);
        padding: 8px 10px;
        font-size: 0.78rem;
      }

      @media (max-width: 920px) {
        .hero {
          grid-template-columns: 1fr;
          grid-template-areas:
            "intro"
            "sketch"
            "timeline";
        }

        .sketch-panel {
          position: relative;
          top: auto;
          min-height: auto;
        }

        .sketchbook {
          min-height: 390px;
        }
      }

      @media (max-width: 560px) {
        .shell {
          width: min(100% - 24px, 1180px);
          padding-top: 18px;
        }

        .topbar {
          align-items: flex-start;
          flex-direction: column;
        }

        h1 {
          font-size: clamp(2.6rem, 18vw, 4rem);
        }

        .moment {
          grid-template-columns: 1fr;
          gap: 8px;
        }

        .sketchbook {
          min-height: 330px;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand-mark">SP</span>
          <span>Portfolio visual prototype</span>
        </a>
        <a class="back-link" href="/">Back to portfolio</a>
