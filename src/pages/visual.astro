    <script is:inline define:vars={{ cities }}>
      const cityData = new Map(cities.map((city) => [city.id, city]));
      const triggers = document.querySelectorAll('[data-city]');
      const sketches = document.querySelectorAll('[data-sketch-city]');
      const title = document.getElementById('city-title');
      const kicker = document.getElementById('city-kicker');
      const meta = document.getElementById('city-meta');
      const copy = document.getElementById('city-copy');
      const sketchNote = document.getElementById('city-sketch-note');

      function activateCity(cityId) {
        const city = cityData.get(cityId);
        if (!city) return;

        triggers.forEach((trigger) => {
          trigger.classList.toggle('is-active', trigger.dataset.city === cityId);
        });

        sketches.forEach((sketch) => {
          sketch.classList.toggle('is-visible', sketch.dataset.sketchCity === cityId);
        });

        title.textContent = city.label;
        kicker.textContent = city.chapter;
        meta.textContent = city.stat;
        copy.textContent = city.detail;
        sketchNote.textContent = city.sketchNote;
      }

      triggers.forEach((trigger) => {
        trigger.addEventListener('mouseenter', () => activateCity(trigger.dataset.city));
        trigger.addEventListener('focus', () => activateCity(trigger.dataset.city));
        trigger.addEventListener('click', () => activateCity(trigger.dataset.city));
      });
    </script>
