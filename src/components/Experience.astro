---
import { experiences, impactStats as impacts } from '../data/profile';
---

<section id="experience" class="py-16 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12 reveal">
      <h2 class="text-2xl md:text-3xl font-bold">
        <span class="gradient-text">Experience</span>
      </h2>
    </div>

    <!-- Impact Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12 reveal">
      {impacts.map((item) => (
        <div class="card p-4 text-center">
          <p class="text-2xl font-bold gradient-text">{item.metric}</p>
          <p class="text-sm text-[var(--color-text-muted)]">{item.label}</p>
        </div>
      ))}
    </div>

    <!-- Timeline -->
    <div class="space-y-6 stagger-children">
      {experiences.map((exp) => (
        <div class="card p-6">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <h3 class="text-lg font-semibold">{exp.title}</h3>
                {exp.isCurrent && (
                  <span class="flex items-center gap-1 text-xs text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                    Current
                  </span>
                )}
              </div>
              <p class="text-[var(--color-primary)] font-medium">{exp.company}</p>
            </div>
            <span class="text-sm text-[var(--color-text-muted)] font-mono">{exp.period}</span>
          </div>

          <ul class="space-y-2">
            {exp.highlights.map((highlight) => (
              <li class="text-sm text-[var(--color-text-secondary)] flex items-start gap-2">
                <svg class="w-4 h-4 text-[var(--color-primary)] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                </svg>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
