<style>
  .city-card-sketch {
    position: absolute;
    right: -8%;
    top: 1.15rem;
    z-index: 0;
    width: min(40%, 390px);
    min-width: 270px;
    color: rgba(148, 163, 184, 0.23);
    opacity: 0.76;
    pointer-events: none;
    transform: rotate(-1.5deg);
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 0, 0, 0.2) 18%,
      rgba(0, 0, 0, 0.88) 48%,
      #000 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 0, 0, 0.2) 18%,
      rgba(0, 0, 0, 0.88) 48%,
      #000 100%
    );
  }

  :global([data-theme='light']) .city-card-sketch {
    color: rgba(15, 23, 42, 0.16);
    opacity: 0.76;
  }

  .city-card-sketch svg {
    display: block;
    width: 100%;
  }

  .city-drawing {
    display: none;
  }

  .city-drawing.is-visible {
    display: block;
  }

  .draw-line,
  .draw-detail,
  .draw-hatch,
  .draw-light,
  .draw-fill {
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .draw-line {
    fill: none;
    stroke-width: 1.65;
    filter: url(#card-rough-pencil);
  }

  .draw-detail {
    fill: none;
    stroke-width: 0.95;
    opacity: 0.56;
  }

  .draw-hatch,
  .draw-light {
    fill: none;
    stroke-width: 0.85;
    opacity: 0.42;
  }

  .draw-light {
    opacity: 0.28;
  }

  .draw-fill {
    fill: currentColor;
    fill-opacity: 0.06;
    stroke-width: 0.95;
  }

  :global(.experience-card),
  :global(.education-card) {
    overflow: hidden;
  }

  :global(.experience-card > :not(.city-card-sketch)),
  :global(.education-card > :not(.city-card-sketch)) {
    position: relative;
    z-index: 1;
  }

  :global(.city-inline) {
    display: inline-flex;
    align-items: center;
    margin-left: 0.4rem;
    padding: 0.2rem 0.42rem;
    border: 1px solid var(--border);
    background: rgba(6, 182, 212, 0.08);
    color: var(--primary);
    font-size: 0.78rem;
    line-height: 1.2;
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .city-card-sketch {
      right: -30%;
      top: 1.25rem;
      width: 64%;
      min-width: 220px;
      opacity: 0.36;
    }
  }
</style>
