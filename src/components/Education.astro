---
import { education } from '../data/profile';
---

<section id="education" class="py-16 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12 reveal">
      <h2 class="text-2xl md:text-3xl font-bold">
        <span class="gradient-text">Education</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6 stagger-children">
      {education.map((edu) => (
        <div class="card p-5 text-center">
          <span class="text-sm text-[var(--color-primary)] font-mono">{edu.year}</span>
          <h3 class="font-semibold mt-1">{edu.degree}</h3>
          <p class="text-sm text-[var(--color-text-secondary)] mt-1">{edu.school}</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-2">{edu.detail}</p>
        </div>
      ))}
    </div>
  </div>
</section>
