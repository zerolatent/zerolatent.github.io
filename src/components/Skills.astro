---
import { skillGroups } from '../data/profile';
---

<section id="skills" class="py-16 px-6 bg-[var(--color-bg-secondary)]">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12 reveal">
      <h2 class="text-2xl md:text-3xl font-bold">
        <span class="gradient-text">Skills</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
      {skillGroups.map((group) => (
        <div class="card p-5">
          <h3 class="font-semibold text-[var(--color-primary)] mb-3">{group.name}</h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="text-sm px-3 py-1 bg-[var(--color-bg-secondary)] rounded-full text-[var(--color-text-secondary)]">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
